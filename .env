# Puerto local donde escucha este servicio Origin
PORT=4001

# Identidad lógica del nodo
NODE_KEY=origin-central
NODE_TYPE=origin
NODE_NAME=Origin Central

# URL base pública desde la cual otros equipos acceden a este Origin
PUBLIC_BASE_URL=http://192.168.10.27:4001

# Conexión MongoDB
# IMPORTANTE: esta base debe ser la correcta según dónde estén los canales reales
# ACLARACION: debe la direccion donde se instalo mongodb para ser usada como backend
MONGO_URI=mongodb://127.0.0.1:27017/wishnet_tv_core

# Ruta donde el Origin va a guardar los HLS generados
HLS_ROOT=./storage/hls

# Comando de ffmpeg disponible en PATH
FFMPEG_PATH=C:\Users\Diego\AppData\Local\Microsoft\WinGet\Links\ffmpeg.exe

# Tiempo de inactividad antes de cerrar un canal
CHANNEL_IDLE_TIMEOUT_MS=120000